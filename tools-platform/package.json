{
  "name": "tools-platform",
  "version": "1.0.0",
  "description": "Tools Platform Desktop App",
  "main": "electron-main.js",
  "scripts": {
    "start": "node backend/server.js",
    "start:desktop": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.toolsplatform.app",
    "productName": "Tools Platform",
    "directories": {
      "output": "dist"
    },
    "files": [
      "backend/**/*",
      "frontend/**/*",
      "electron-main.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^6.0.1",
    "uuid": "^9.0.0",
    "@google/generative-ai": "^0.24.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
